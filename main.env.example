# Resume Parser Configuration
# Copy this file to main.env and add your actual API keys
# The parser works without keys using local fallback

# OpenRouter API (Free tier available at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_key_here

# Google Gemini API (Free tier available at https://ai.google.dev)
GEMINI_API_KEY=your_gemini_key_here

# Groq API (Free tier available at https://console.groq.com)
GROQ_API_KEY=your_groq_key_here

# Deepseek API (optional)
DEEPSEEK_API_KEY=your_deepseek_key_here

# Nvidia API (optional)
NVIDIA_API_KEY=your_nvidia_key_here
